{
  "name": "@aguhot/web",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "typecheck": "tsc --noEmit && tsc --noEmit -p tsconfig.e2e.json",
    "lint": "eslint .",
    "verify:follow-ref": "tsx \"app/(public)/_actions/follow-ref-parser.selfcheck.ts\"",
    "verify:session-cookie": "tsx lib/session-cookie-signer.selfcheck.ts",
    "verify:watchlist": "tsx lib/watchlist.selfcheck.ts",
    "verify:operator-auth": "tsx lib/operator-auth.selfcheck.ts",
    "e2e": "NO_PROXY=localhost,127.0.0.1 no_proxy=localhost,127.0.0.1 playwright test --grep-invert \"@console|@feed|@detail|@revision|@merge-split|@market-reaction|@associations|@themes|@daily|@loop|@search|@follow|@watchlist|@search-return\"",
    "e2e:a11y": "NO_PROXY=localhost,127.0.0.1 no_proxy=localhost,127.0.0.1 playwright test --grep @a11y",
    "e2e:console": "tsx e2e/seed-console.ts && NO_PROXY=localhost,127.0.0.1 no_proxy=localhost,127.0.0.1 playwright test --grep @console",
    "e2e:feed": "tsx e2e/seed-feed.ts && NO_PROXY=localhost,127.0.0.1 no_proxy=localhost,127.0.0.1 playwright test --grep @feed",
    "e2e:detail": "NO_PROXY=localhost,127.0.0.1 no_proxy=localhost,127.0.0.1 playwright test --grep @detail",
    "e2e:revision": "NO_PROXY=localhost,127.0.0.1 no_proxy=localhost,127.0.0.1 playwright test --grep @revision",
    "e2e:merge-split": "NO_PROXY=localhost,127.0.0.1 no_proxy=localhost,127.0.0.1 playwright test --grep @merge-split",
    "e2e:market-reaction": "NO_PROXY=localhost,127.0.0.1 no_proxy=localhost,127.0.0.1 playwright test --grep @market-reaction",
    "e2e:associations": "NO_PROXY=localhost,127.0.0.1 no_proxy=localhost,127.0.0.1 playwright test --grep @associations",
    "e2e:themes": "NO_PROXY=localhost,127.0.0.1 no_proxy=localhost,127.0.0.1 playwright test --grep @themes",
    "e2e:daily": "NO_PROXY=localhost,127.0.0.1 no_proxy=localhost,127.0.0.1 playwright test --grep @daily",
    "e2e:loop": "tsx e2e/seed-loop.ts && NO_PROXY=localhost,127.0.0.1 no_proxy=localhost,127.0.0.1 playwright test --grep @loop",
    "e2e:search": "tsx e2e/seed-search.ts && NO_PROXY=localhost,127.0.0.1 no_proxy=localhost,127.0.0.1 playwright test --grep \"@search[^-]\"",
    "e2e:search-return": "tsx e2e/seed-search.ts && NO_PROXY=localhost,127.0.0.1 no_proxy=localhost,127.0.0.1 playwright test --grep @search-return",
    "e2e:follow": "tsx e2e/seed-follow.ts && NO_PROXY=localhost,127.0.0.1 no_proxy=localhost,127.0.0.1 SESSION_SECRET=dev-follow-e2e-secret-32chars playwright test --grep @follow",
    "e2e:watchlist": "tsx e2e/seed-watchlist.ts && NO_PROXY=localhost,127.0.0.1 no_proxy=localhost,127.0.0.1 SESSION_SECRET=dev-watchlist-e2e-secret-32chars playwright test --grep @watchlist",
    "seed:console": "tsx e2e/seed-console.ts",
    "seed:feed": "tsx e2e/seed-feed.ts",
    "seed:detail": "tsx e2e/seed-detail.ts",
    "seed:revision": "tsx e2e/seed-revision.ts",
    "seed:merge-split": "tsx e2e/seed-merge-split.ts",
    "seed:market-reaction": "tsx e2e/seed-market-reaction.ts",
    "seed:associations": "tsx e2e/seed-associations.ts",
    "seed:themes": "tsx e2e/seed-themes.ts",
    "seed:daily": "tsx e2e/seed-daily.ts",
    "seed:loop": "tsx e2e/seed-loop.ts",
    "seed:search": "tsx e2e/seed-search.ts",
    "seed:follow": "tsx e2e/seed-follow.ts",
    "seed:watchlist": "tsx e2e/seed-watchlist.ts"
  },
  "dependencies": {
    "@aguhot/config": "workspace:*",
    "@aguhot/core": "workspace:*",
    "@base-ui/react": "1.6.0",
    "clsx": "^2.1.1",
    "next": "16.2.10",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "tailwind-merge": "^3.3.1"
  },
  "devDependencies": {
    "@playwright/test": "1.60.0",
    "@tailwindcss/postcss": "^4.3.2",
    "@types/node": "^24.0.0",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "eslint": "^9.0.0",
    "eslint-config-next": "16.2.10",
    "tailwindcss": "^4.3.2",
    "tsx": "^4.19.0",
    "typescript": "^5.9.3"
  }
}
