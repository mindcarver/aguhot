{
  "name": "@aguhot/worker",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "./src/index.ts",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "verify:ingest": "tsx src/verify-ingest.ts",
    "verify:cluster": "tsx src/verify-cluster.ts",
    "verify:publish": "tsx src/verify-publish.ts",
    "verify:explain": "tsx src/verify-explain.ts",
    "verify:revision": "tsx src/verify-revision.ts",
    "verify:merge-split": "tsx src/verify-merge-split.ts",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src",
    "build": "tsc --noEmit"
