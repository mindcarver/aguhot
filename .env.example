# AGUHOT environment variables
# Copy to .env and fill in real values. Parsed by packages/config (zod).
# The web skeleton homepage is anonymous and never touches DB/Redis,
# so a missing DATABASE_URL / REDIS_URL does not block `build` or first paint.

# Runtime environment (development | test | production)
NODE_ENV=development

# PostgreSQL 18 (Prisma 7.7 connection string). Required by worker + operator flows.
DATABASE_URL=postgresql://aguhot:aguhot@localhost:5432/aguhot?schema=public

# Redis 8 (BullMQ 5.79 queues). Required by worker.
REDIS_URL=redis://localhost:6379

# App
NEXT_PUBLIC_APP_NAME=AGUHOT
