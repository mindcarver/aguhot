+-- CreateTable
+CREATE TABLE "follow_targets" (
+    "id" TEXT NOT NULL,
+    "user_account_id" TEXT NOT NULL,
+    "target_kind" TEXT NOT NULL,
+    "target_hot_event_id" TEXT,
+    "target_theme_slug" TEXT,
