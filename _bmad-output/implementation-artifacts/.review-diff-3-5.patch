diff --git a/apps/web/app/globals.css b/apps/web/app/globals.css
index 691eacd..c01ac27 100644
--- a/apps/web/app/globals.css
+++ b/apps/web/app/globals.css
@@ -80,3 +80,27 @@
   --radius-lg: 14px;
   --radius-xl: 20px;
 }
+
+/* Story 3.5 — keyboard a11y baseline: one global `:focus-visible` rule.
+ *
+ * Before 3.5 only SearchBox and FollowButton had explicit focus rings
+ * (`focus:outline-none focus-visible:ring-2 focus-visible:ring-focus-ring`);
+ * every nav link / FilterPill / card link / BackLink / detail external link
+ * relied on the browser default outline, which is not the brand focus color
+ * and therefore not a consistent visible-focus baseline. This single rule
+ * fills that gap for EVERY focusable element across all six public surfaces
+ * + every shared component, with zero per-component `focus:` classes.
+ *
+ * `:where()` keeps specificity at 0, so components that already carry
+ * `focus:outline-none focus-visible:ring-2 focus-visible:ring-focus-ring`
+ * (compiled by Tailwind to specificity > 0) keep their own ring and are NOT
+ * overridden — no double indicator, no regression. Elements without any
+ * focus class receive the brand-color outline via this rule. The token
+ * `--color-focus-ring` is the existing 1.3 DESIGN token (#335A91), so no
+ * new token is introduced.
+ */
+:where(a, button, input, textarea, select, summary):focus-visible {
+  outline: 2px solid var(--color-focus-ring);
+  outline-offset: 2px;
+  border-radius: var(--radius-sm);
+}
