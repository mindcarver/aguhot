import { resetEnvCache, requireEnv } from "@aguhot/config";

const HOUR = 60 * 60 * 1000;
const DAY = 24 * HOUR;

export async function seedThemeEvents(): Promise<{
  themeSlug: string;
  themeLabel: string;
