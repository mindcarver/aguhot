   @@index([publicationStatus])
   @@map("hot_events")
@@ -840,3 +851,62 @@ model RecommendationReason {
   @@index([createdAt])
   @@map("recommendation_reasons")
 }
+
+// Story 5.2 — append-only AI 深读 (event-level "为什么重要" deep read). Same shape
+// and ownership rules as RecommendationReason above: rows are append-only, so the
+// chain ordered by created_at is the auditable history (NFR-7 version +
+// provenance: model_id + prompt_version + source on every row). The
+// publish-orchestrator projection (projectDeepRead) projects the LATEST row
+// (created_at desc first) into published_hot_event_deep_reads — publish-
+// orchestrator stays the SOLE writer of that projection (AD-2/AD-3); the worker
+// only appends here + calls refreshPublishedReadModel.
+//
+// Distinct from ExplanationVersion (a DIFFERENT three-partition: summary/
+// whyItMatters/uncertainties — the deterministic template three-block that stays
+// on the same detail page). DeepRead is a separate append-only table carrying
+// 影响面/受益方/风险点 per row (epic-5-context data-model decision: three
+// independent append-only tables, do not reuse ExplanationVersion).
+//
+// FK onDelete: Cascade so a HotEvent deletion cleans up its AI 深读 history.
+// `source` is "ai" in V1 (real LLM deferred; the stub also writes "ai" so the
+// projection pipeline is identical — only the model_id/prompt_version mark it as
+// stub-generated).
+model DeepRead {
+  id            String   @id // UUIDv7, assigned in application code (newTraceId)
+  hotEventId    String   @map("hot_event_id")
+  impactSurface String   @map("impact_surface") // 影响面; ≤120 字; guardrail-enforced at write time
+  beneficiaries String // 受益方; ≤120 字; guardrail-enforced at write time
+  riskPoints    String   @map("risk_points") // 风险点; ≤120 字; guardrail-enforced at write time
+  source        String // ExplanationSource union value ("ai" in V1)
+  modelId       String   @map("model_id") // provider + version (e.g. "stub:v1", future "openai:gpt-4o")
+  promptVersion String   @map("prompt_version") // prompt template version (e.g. "deepread-stub-v1")
+  traceId       String?  @map("trace_id")
+  createdAt     DateTime @default(now()) @map("created_at")
+
+  hotEvent HotEvent @relation(fields: [hotEventId], references: [id], onDelete: Cascade)
+
+  @@index([hotEventId])
+  @@index([createdAt])
+  @@map("deep_reads")
+}
+
+// Public read-model projection of the latest DeepRead row (AD-3 public projection,
+// one row per published HotEvent). publish-orchestrator is the SOLE writer
+// (projectDeepRead inside refreshPublishedReadModel; AD-2/AD-3); the detail page
+// reads it via getPublishedHotEventDetail. deep_read_source/generated_at come from
+// the latest DeepRead row (always "ai" in V1). Cleared on takedown alongside the
+// other published_* read models. Mirrors published_hot_event_explanations.
+model PublishedHotEventDeepRead {
+  hotEventId     String   @id @map("hot_event_id")
+  impactSurface  String   @map("impact_surface")
+  beneficiaries  String
+  riskPoints     String   @map("risk_points")
+  deepReadSource String   @map("deep_read_source") // ExplanationSource union value
+  generatedAt    DateTime @map("generated_at")
+  traceId        String?  @map("trace_id")
+  updatedAt      DateTime @updatedAt @map("updated_at")
+
+  hotEvent HotEvent @relation(fields: [hotEventId], references: [id], onDelete: Cascade)
+
+  @@map("published_hot_event_deep_reads")
+}
