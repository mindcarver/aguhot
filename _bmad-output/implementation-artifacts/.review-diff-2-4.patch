+export interface GenerateDailyDigestOptions {
+  prisma: PrismaClient;
+  traceId: string;
+  coverageDate: Date;
+  adapter?: DigestAdapter;
+}
+
+/**
+ * The result of a successful generation: the newly-appended digest's id + the
