+ */
+export interface AiContentSamplingItem {
+  type: AiContentType;
+  id: string;
+  hotEventId: string;
+  eventTitle: string;
+  content: string;
+  source: string;
+  createdAt: Date;
+  suppressedAt: Date | null;
+}
