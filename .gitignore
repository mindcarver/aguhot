dist/
build/
.next/
out/
.turbo/
*.tsbuildinfo

# Env (only .env.example is tracked)
.env
.env.local
.env.*.local

# Test artifacts
coverage/
playwright-report/
test-results/
.playwright/

# Logs
*.log
npm-debug.log*
pnpm-debug.log*

# Editor / OS
.DS_Store
.idea/
.vscode/*
!.vscode/settings.json

# Claude Code scheduled-task runtime state (cron; changes on every fire)
.claude/scheduled_tasks.json
.claude/scheduled_tasks.lock
