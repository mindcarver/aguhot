strict-peer-dependencies=false
auto-install-peers=true
shamefully-hoist=false

# install-lifecycle scripts are gated by pnpm 10's onlyBuiltDependencies
# allowlist in pnpm-workspace.yaml (not a blanket ignore-scripts). This keeps
# unrs-resolver / resolve postinstalls skipped (not in the allowlist, so the
# China-network GitHub fetch + meaningless `lerna bootstrap` never run) while
# permitting the Prisma engine download postinstall that @prisma/client /
# prisma / @prisma/engines need at install time.
