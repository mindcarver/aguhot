strict-peer-dependencies=false
auto-install-peers=true
shamefully-hoist=false

# Skip install-lifecycle scripts. unrs-resolver's postinstall forces a GitHub
# fetch (hangs on China network) even though its native binary is already
# installed via the @unrs/resolver-binding-darwin-arm64 platform package, and
# resolve@2 runs a meaningless `lerna bootstrap`. All native deps here ship
# prebuilt platform packages, so no postinstall is actually needed. This keeps
# every `pnpm install` (incl. bmad-loop dev sessions) fast and hang-free.
ignore-scripts=true
