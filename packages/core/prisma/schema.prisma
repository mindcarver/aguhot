// Prisma 7 schema for @aguhot/core — evidence source ingest & archive.
//
// Generator is `prisma-client` (Prisma 7 default), emitting the typed client
// into ../generated (gitignored, regenerated by `db:generate`). The datasource
// block declares only the provider; the connection string is injected at
// runtime via the @prisma/adapter-pg driver adapter (see src/db.ts) and at
// CLI time via prisma.config.ts. This keeps the public web build free of any
// DATABASE_URL dependency (AD-3/AD-6) while the worker is the single writer
// of the evidence_* tables (AD-2).

generator client {
  provider = "prisma-client"
  output   = "../generated"
}

datasource db {
  provider = "postgresql"
}

// A configured evidence source. source-ingest is the sole write-owner of this
// table (AD-2). `kind` selects which SourceAdapter the worker resolves at
// runtime (AD-7); `feed_url` is the adapter-specific locator (RSS feed URL,
// future API endpoint, etc.). `enabled` gates whether ingestSources() visits
// the source. `last_error` records the most recent per-source failure so a
// single broken source never aborts the rest (AC3 isolation) and stays
// traceable rather than silently dropped.
model EvidenceSource {
  id        String   @id // UUIDv7, assigned in application code (newTraceId)
  name      String
  kind      String // SourceKind union value ("rss"); stored as String, no TS enum
  feedUrl   String   @map("feed_url")
  enabled   Boolean  @default(true)
  lastError String?  @map("last_error")
  traceId   String?  @map("trace_id")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  records EvidenceRecord[]

  @@map("evidence_sources")
}

// An archived evidence record produced from a single ingested item. The
// source-ingest module is the sole writer (AD-2). `content_hash` is the
// deduplication key (sha256 of normalized url+title+published_at): a re-ingest
// of the same item upserts with an empty update (skip) so existing records are
// never overwritten (AC1 dedup). Records with missing required fields are still
// archived with status="missing_fields" and a human-readable failure_reason
// (AC3 traceability) rather than being discarded.
model EvidenceRecord {
  id            String    @id // UUIDv7, assigned in application code (newTraceId)
  sourceId      String    @map("source_id")
  url           String?
  title         String?
  summary       String?
  publishedAt   DateTime? @map("published_at")
  ingestedAt    DateTime  @default(now()) @map("ingested_at")
  contentHash   String    @unique @map("content_hash")
  status        String // IngestStatus union value ("archived"|"missing_fields")
  failureReason String?   @map("failure_reason")
  rawPayload    Json      @map("raw_payload")
  traceId       String?   @map("trace_id")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  source EvidenceSource @relation(fields: [sourceId], references: [id])

  // Read-only reverse relation (Prisma navigation metadata, not a write path):
  // lets event-assembly query unlinked archived records efficiently via
  // `where: { evidenceLinks: { none: {} } }` (compiles to NOT EXISTS). Adding
  // this relation does NOT change source-ingest's write-ownership of
  // evidence_records (AD-2): event-assembly only writes hot_event_evidence rows
  // that reference evidence_records.id, never evidence_records itself.
  evidenceLinks HotEventEvidence[]

  // Indexes reference the Prisma field name, not the @map column name.
  @@index([sourceId])
  @@index([status])
  @@map("evidence_records")
}

// A candidate hot event produced by clustering archived evidence records.
// The event-assembly module owns creation + (title, cluster_signature) writes
// (AD-2); review-workflow owns the `publication_status` field writes (AD-6 —
// field-level write-ownership, see Design Notes in spec-1-6: two modules write
// hot_events but different, non-overlapping fields). A candidate is never
// visible publicly until review-workflow transitions publication_status to
// "published" and publish-orchestrator upserts the published_hot_events read
// model. event-assembly only ever assigns "candidate"; review-workflow drives
// candidate→published / candidate→rejected / published→taken_down.
//
// `publication_status` is a String column with a TS union (no Prisma enum, per
// erasableSyntaxOnly). The authoritative union lives in shared/publication-
// status.ts (candidate|published|rejected|taken_down) and is re-exported from
// event-assembly/types.ts to keep the 1-5 public API stable. `cluster_signature`
// is the sorted token-union signature of the cluster's member records (see
// signatureOf in clustering.ts); it is the key used for incremental merge: a
// newly archived record whose tokens overlap an existing candidate's signature
// joins that candidate instead of spawning a duplicate. `title` is a naive
// derivation (latest published_at record's title, non-AI) — real title/
// explanation generation is the separate explain job (1.8).
model HotEvent {
  id                String   @id // UUIDv7, assigned in application code (newTraceId)
  title             String
  clusterSignature  String   @map("cluster_signature")
  publicationStatus String   @map("publication_status") // PublicationStatus union value (shared/publication-status.ts)
  // Story 7.1/7.2 — investment-relevance gate + significance score. event-assembly
  // is the SOLE writer of these three fields (AD-2b): they are computed at cluster
  // time from the candidate's member evidence (relevance keywords + breadth +
  // velocity). `relevance_label` is the RelevanceLabel union ("pass"|"suspicious"
  // |"fail"); `saliency` is the 0–100 significance score; `saliency_breakdown` is
  // the Json component breakdown ({breadth,velocity,marketReaction,association,
  // total}) used both for the FR-3 sort-reason chip and for publish-time re-score
  // (Story 7.4 folds in marketReaction + association, which are 0 at cluster time
  // because those modules have not run yet). All nullable: pre-7.2 rows + the
  // self-heal path leave them null; the publish gate treats null as "unscored →
  // hold" (never auto-publish an unscored event).
  relevanceLabel    String?  @map("relevance_label") // RelevanceLabel union value
  saliency          Float?   @map("saliency") // 0–100 significance score
  saliencyBreakdown Json?    @map("saliency_breakdown") // SaliencyBreakdown object
  traceId           String?  @map("trace_id")
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  evidence                   HotEventEvidence[]
  // Read-only reverse relations (Prisma navigation metadata, not write paths):
  // let review-workflow list candidates / detail evidence and let
  // publish-orchestrator compute read-model projections without a second query
  // round-trip. Adding these does NOT change event-assembly's write-ownership
  // of (title, cluster_signature) or review-workflow's ownership of
  // publication_status (AD-2/AD-6 field-level split).
  reviewDecisions            ReviewDecision[]
  publicationDecisions       PublicationDecision[]
  publishedReadModel         PublishedHotEvent?
  // Read-only reverse relation to the explain job's append-only explanation
  // versions (Story 1.8). The explanation module owns explanation_versions;
  // this navigation metadata lets publish-orchestrator read the latest version
  // when projecting the published read model. It does NOT change the
  // explanation module's write-ownership (AD-5 append-only versions).
  explanationVersions        ExplanationVersion[]
  // Read-only reverse relations to the two new published detail read models
  // (Story 1.8: published_hot_event_explanations + published_hot_event_evidence).
  // publish-orchestrator owns both; these are navigation metadata only.
  publishedExplanation       PublishedHotEventExplanation?
  publishedEvidence          PublishedHotEventEvidence[]
  // Read-only reverse relation to operator-authored title/tag revisions (Story
  // 1.9). The event-assembly module owns hot_event_revisions (it owns
  // HotEvent clustering + this is the revision write-point per AD-2/AD-5); this
  // navigation metadata lets review-workflow read the latest revision for the
  // operator "pending vs published" diff and lets publish-orchestrator read the
  // effective title/tags at projection time. It does NOT change event-assembly's
  // write-ownership of hot_event_revisions.
  revisions                  HotEventRevision[]
  // Read-only reverse relations to the market-reaction read models (Story 2.1).
  // The market-reaction module owns market_reaction_snapshots (AD-2 append-only
  // write table); publish-orchestrator owns published_hot_event_reactions (AD-3
  // public projection). These navigations let publish-orchestrator read the
  // latest snapshot at projection time and let the market-reaction worker query
  // published events without a snapshot via `marketReactionSnapshots: { none: {} }`.
  // They do NOT change the respective modules' write-ownership (AD-2).
  marketReactionSnapshots    MarketReactionSnapshot[]
  publishedReaction          PublishedHotEventReaction?
  // Read-only reverse relations to the association read models (Story 2.2).
  // The theme-linking module owns event_association_sets (AD-2 append-only write
  // table); publish-orchestrator owns published_hot_event_associations (AD-3
  // public projection). These navigations let publish-orchestrator read the
  // latest set at projection time. They do NOT change the respective modules'
  // write-ownership (AD-2).
  eventAssociationSets       EventAssociationSet[]
  publishedAssociation       PublishedHotEventAssociation?
  // Read-only reverse relations to the theme read models (Story 2.3).
  // The theme-linking module owns event_theme_sets (AD-2 append-only write table,
  // one row per generation of ThemeRef[]); publish-orchestrator owns
  // published_hot_event_themes (AD-3 public projection). These navigations let
  // publish-orchestrator read the latest set at projection time and let the
  // theme-backfill worker query published events without a theme set via
  // `eventThemeSets: { none: {} }`. They do NOT change the respective modules'
  // write-ownership (AD-2).
  eventThemeSets             EventThemeSet[]
  publishedTheme             PublishedHotEventTheme?
  // Read-only reverse relation to the timeline read model (Story 4.1).
  // publish-orchestrator owns published_timeline_entries (AD-3b public
  // projection of per-HotEvent folded timeline rows). This navigation lets the
  // self-heal job find published events whose timeline projection is stale and
  // lets publish-orchestrator delete a HotEvent's timeline rows on takedown. It
  // does NOT change publish-orchestrator's write-ownership (AD-2/AD-3b).
  publishedTimeline          PublishedTimelineEntry[]
  // Read-only reverse relation to the append-only AI 解读 rows (Story 5.1).
  // The explanation module owns recommendation_reasons (AD-5 append-only, one
  // row per generation of the ≤40 字 card hook); publish-orchestrator projects
  // the LATEST row into published_timeline_entries.recommendation_reason (the
  // sole writer of that column stays publish-orchestrator, AD-2/AD-3b). This
  // navigation lets publish-orchestrator read the latest reason at projection
  // time and lets the recommendation-reason worker query events lacking a
  // reason via `recommendationReasons: { none: {} }`. It does NOT change the
  // explanation module's write-ownership of recommendation_reasons.
  recommendationReasons      RecommendationReason[]
  // Read-only reverse relation to the append-only AI 深读 rows (Story 5.2).
  // The explanation module owns deep_reads (AD-5 append-only, one row per
  // generation of the three-segment 影响面/受益方/风险点 detail-page deep read);
  // publish-orchestrator projects the LATEST row into published_hot_event_deep_
  // reads (the sole writer of that projection stays publish-orchestrator,
  // AD-2/AD-3). This navigation lets publish-orchestrator read the latest deep
  // read at projection time and lets the deep-read worker query events lacking a
  // deep read via `deepReads: { none: {} }`. It does NOT change the explanation
  // module's write-ownership of deep_reads.
  deepReads                  DeepRead[]
  publishedDeepRead          PublishedHotEventDeepRead?
  // Read-only reverse relation to the append-only 投资标的池 rows. The investment-
  // targets module owns investment_targets (AD-5 append-only, one row per agent
  // run of the ashare-news-investment-targets skill — candidates[] carried as Json,
  // mirroring TrendBriefing.basedOnHotEventIds); publish-orchestrator projects the
  // LATEST row into published_hot_event_investment_targets (the sole writer of that
  // projection stays publish-orchestrator, AD-2/AD-3). This navigation lets
  // publish-orchestrator read the latest pool at projection time and lets the
  // investment-targets worker query events lacking a pool via
  // `investmentTargets: { none: {} }`. It does NOT change the module's write-
  // ownership of investment_targets.
  investmentTargets          InvestmentTarget[]
  publishedInvestmentTargets PublishedHotEventInvestmentTargets?

  @@index([publicationStatus])
  @@map("hot_events")
}

// Link table between a candidate HotEvent and its supporting EvidenceRecord.
// Each candidate is traceable to >= 1 evidence record (AC1). The link table is
// also the "already processed" marker: clusterEvents queries archived records
// with `evidenceLinks: { none: {} }` (NOT EXISTS), so a re-run over the same
// evidence set has an empty processing set — the idempotency key. The unique
// constraint on (hot_event_id, evidence_record_id) is the tail guard against a
// duplicate link under concurrency.
model HotEventEvidence {
  id               String   @id // UUIDv7, assigned in application code (newTraceId)
  hotEventId       String   @map("hot_event_id")
  evidenceRecordId String   @map("evidence_record_id")
  traceId          String?  @map("trace_id")
  createdAt        DateTime @default(now()) @map("created_at")

  hotEvent       HotEvent       @relation(fields: [hotEventId], references: [id])
  evidenceRecord EvidenceRecord @relation(fields: [evidenceRecordId], references: [id])

  @@unique([hotEventId, evidenceRecordId])
  @@index([evidenceRecordId])
  @@index([hotEventId])
  @@map("hot_event_evidence")
}

// An append-only operator decision on a candidate HotEvent (AD-5/AD-6). The
// review-workflow module is the sole writer of this table. Each row records one
// approve/reject/takedown outcome; rows are never updated or deleted — the full
// chain (ordered by created_at) is the auditable history of who decided what,
// when, and why. `outcome` is a String column with the ReviewOutcome union
// (approve|reject|takedown). FK onDelete: Restrict so deleting a HotEvent can
// never silently erase review history (audit traceability, AD-5).
model ReviewDecision {
  id         String   @id // UUIDv7, assigned in application code (newTraceId)
  hotEventId String   @map("hot_event_id")
  outcome    String // ReviewOutcome union value ("approve"|"reject"|"takedown"|"republish") OR the sibling "suppress_ai_content" outcome (Story 5.4 — written directly to this free-String column, NOT added to the ReviewOutcome const / state machine)
  reviewer   String // operator identity (V1: placeholder; real auth deferred)
  note       String? // optional operator note
  // Story 5.4 — suppress_ai_content target. Nullable: the traditional 4-outcome
  // decisions leave both null (the decision is per-HotEvent, identified by
  // hotEventId). A suppress_ai_content decision sets targetType ∈ {"reason",
  // "deepread"} + targetId = the suppressed RecommendationReason.id /
  // DeepRead.id (structured audit: which generated AI content was judged
  // misleading + which exact source row). Kept as a free String (no TS enum, per
  // erasableSyntaxOnly); the AiContentType const lives in the explanation module.
  targetType String?  @map("target_type")
  targetId   String?  @map("target_id")
  traceId    String?  @map("trace_id")
  createdAt  DateTime @default(now()) @map("created_at")

  hotEvent            HotEvent             @relation(fields: [hotEventId], references: [id])
  publicationDecision PublicationDecision?

  @@index([hotEventId])
  @@index([createdAt])
  @@map("review_decisions")
}

// An append-only record of a publication_status transition (AD-5/AD-6). The
// review-workflow module is the sole writer. Each row records the from→to
// transition driven by a ReviewDecision (linked via review_decision_id) and is
// the auditable proof that a candidate became published, was rejected, or a
// published event was taken down. Rows are never updated or deleted. FK
// onDelete: Restrict so deleting a HotEvent can never erase publication history.
// `from_status`/`to_status` are PublicationStatus union values.
model PublicationDecision {
  id               String   @id // UUIDv7, assigned in application code (newTraceId)
  hotEventId       String   @map("hot_event_id")
  fromStatus       String   @map("from_status") // PublicationStatus union value
  toStatus         String   @map("to_status") // PublicationStatus union value
  reason           String? // optional operator-facing reason
  reviewDecisionId String?  @unique @map("review_decision_id")
  traceId          String?  @map("trace_id")
  createdAt        DateTime @default(now()) @map("created_at")

  hotEvent       HotEvent        @relation(fields: [hotEventId], references: [id])
  reviewDecision ReviewDecision? @relation(fields: [reviewDecisionId], references: [id])

  @@index([hotEventId])
  @@index([createdAt])
  @@map("publication_decisions")
}

// The public read model for published hot events (AD-3). The publish-
// orchestrator module is the sole writer of this table. Row existence = current
// publication: approve upserts the row (public-visible), takedown deletes it
// (public-invisible). There is intentionally NO status column — row existence
// is the visibility contract, so public reads are just "SELECT * FROM
// published_hot_events" with no WHERE filter to forget (see Design Notes in
// spec-1-6). FK onDelete: Cascade so a HotEvent deletion cleans up its read
// model row (the decision history is preserved in review_decisions/
// publication_decisions via their own Restrict FKs). `published_at` is the time
// this event became public (set on first publish; kept stable across refreshes).
// `evidence_count`/`latest_evidence_at` are recomputed on every publish refresh.
model PublishedHotEvent {
  hotEventId       String   @id @map("hot_event_id")
  title            String
  // Operator-authored free-text tags (Story 1.9), projected from the effective
  // HotEventRevision.tags at publish/republish time. Default [] is safe for
  // rows created by pre-1.9 approves (no revision existed → empty tag set).
  // V1 tags are a display attribute on the detail page only — NOT a feed filter
  // dimension (that belongs to Epic 2.2 taxonomy). listPublishedHotEvents /
  // PublishedHotEventSummary intentionally do NOT surface tags (1.7 feed
  // contract unchanged); only getPublishedHotEventDetail returns them.
  tags             String[] @default([])
  evidenceCount    Int      @map("evidence_count")
  latestEvidenceAt DateTime @map("latest_evidence_at")
  // Story 7.5 — projected saliency for feed ranking. publish-orchestrator is the
  // SOLE writer (projects HotEvent.saliency at publish/republish, re-scored with
  // market-reaction + association per Story 7.4). Nullable for pre-7.5 rows; the
  // feed orderBy falls back to evidenceCount when null (defensive — should not
  // occur for post-7.5 publishes). listPublishedHotEvents swaps evidenceCount DESC
  // for saliency DESC (Story 7.5).
  saliency         Float?   @map("saliency")
  publishedAt      DateTime @default(now()) @map("published_at")
  traceId          String?  @map("trace_id")
  updatedAt        DateTime @updatedAt @map("updated_at")

  hotEvent HotEvent @relation(fields: [hotEventId], references: [id])

  @@map("published_hot_events")
}

// An append-only explanation version for a HotEvent (AD-5). The explanation
// module is the sole writer of this table (Story 1.8). Each row records the
// three explanation partitions — summary (发生了什么), whyItMatters (为什么重要),
// uncertainties (当前仍不确定什么) — derived deterministically from the member
// evidence records (V1 source="template"; future source="ai"/"human"). Rows are
// NEVER updated or deleted: every generation appends a new row, so the full
// version chain (ordered by created_at) is the auditable history of which
// version came from which source and when. The public read model projects the
// latest version (created_at desc first) into published_hot_event_explanations;
// operator-console version-chain consumption lands in 1.9.
//
// FK onDelete: Cascade so a HotEvent deletion cleans up its explanation history.
// `source` distinguishes provenance ("template" V1 deterministic derivation;
// "ai" when a real LLM lands; "human" for operator-authored revisions in 1.9).
model ExplanationVersion {
  id            String   @id // UUIDv7, assigned in application code (newTraceId)
  hotEventId    String   @map("hot_event_id")
  summary       String
  whyItMatters  String   @map("why_it_matters")
  uncertainties String
  source        String // ExplanationSource union value ("template"|"ai"|"human")
  traceId       String?  @map("trace_id")
  createdAt     DateTime @default(now()) @map("created_at")

  hotEvent HotEvent @relation(fields: [hotEventId], references: [id], onDelete: Cascade)

  @@index([hotEventId])
  @@index([createdAt])
  @@map("explanation_versions")
}

// The public read model for a published hot-event explanation (AD-3, Story 1.8).
// The publish-orchestrator module is the sole writer. Row existence = currently
// published: publish upserts the row (projecting the latest ExplanationVersion),
// takedown deletes it. There is intentionally NO status column — row existence
// is the visibility contract (same pattern as published_hot_events). FK onDelete:
// Cascade so a HotEvent deletion cleans up the projection. `explanation_source`
// records the provenance of the projected version (operator audit), and
// `generated_at` records when that version was generated (so the public surface
// can show "解释生成于 <time>"). A row may be ABSENT while the event is
// published if the explain job has not run yet — the detail page renders an
// honest degraded state in that case (never fabricates an explanation).
model PublishedHotEventExplanation {
  hotEventId        String   @id @map("hot_event_id")
  summary           String
  whyItMatters      String   @map("why_it_matters")
  uncertainties     String
  explanationSource String   @map("explanation_source") // ExplanationSource union value
  generatedAt       DateTime @map("generated_at")
  traceId           String?  @map("trace_id")
  updatedAt         DateTime @updatedAt @map("updated_at")

  hotEvent HotEvent @relation(fields: [hotEventId], references: [id], onDelete: Cascade)

  @@map("published_hot_event_explanations")
}

// The public read model for a published hot-event evidence timeline (AD-3,
// Story 1.8). The publish-orchestrator module is the sole writer. Each row is
// ONE evidence record projected from hot_event_evidence → evidence_records →
// evidence_sources at publish time (so the public detail page NEVER reads those
// raw tables — AD-3). Rows are deleted on takedown. FK onDelete: Cascade so a
// HotEvent deletion cleans up the projection.
//
// `link_status` is derived from the evidence record's url at projection time:
// url present → "available", url missing/empty → "unavailable". A row is NEVER
// silently dropped for a missing link — the detail page renders an "无原始链接"
// badge so the reader sees the source name/time/summary even without a working
// link (AC2: dead links keep the record with a clearly marked status). Active
// HTTP liveness probing / archive snapshots are a separate concern (deferred).
// `position` is the chronological render order (publishedAt ASC, nulls last),
// assigned at projection time so the public read is a single orderBy position.
model PublishedHotEventEvidence {
  id          String    @id // UUIDv7, assigned in application code (newTraceId)
  hotEventId  String    @map("hot_event_id")
  sourceName  String    @map("source_name")
  url         String?
  summary     String?
  publishedAt DateTime? @map("published_at")
  linkStatus  String    @map("link_status") // EvidenceLinkStatus union value ("available"|"unavailable")
  position    Int
  traceId     String?   @map("trace_id")
  createdAt   DateTime  @default(now()) @map("created_at")

  hotEvent HotEvent @relation(fields: [hotEventId], references: [id], onDelete: Cascade)

  @@index([hotEventId])
  @@map("published_hot_event_evidence")
}

// An append-only operator-authored title/tags revision for a HotEvent (AD-5,
// Story 1.9). The event-assembly module is the sole writer of this table (via
// reviseHotEvent). Each row is the COMPLETE effective snapshot of (title, tags)
// at one operator revision — NOT a delta. Rows are NEVER updated or deleted;
// effective title/tags = latest row (createdAt desc, id desc) ?? the baseline
// (HotEvent.title for the title, [] for tags — clustering does not derive tags).
//
// `title` is the operator's revised title (an overlay on the cluster-derived
// baseline HotEvent.title; the baseline is never overwritten — see AD-5 and
// the field-level write-ownership note in the HotEvent comment). `tags` is a
// free-text operator tag array (PostgreSQL text[]); V1 has NO taxonomy, NO
// tag-level metadata, and NO feed filtering by tag (those belong to Epic 2.2).
// Normalization (trim / split on separators / dedupe preserve-order) happens in
// the application layer before append.
//
// FK onDelete matches ReviewDecision's audit-preserve semantics (Restrict) so
// deleting a HotEvent can never silently erase revision history. `reviewer` is
// the operator identity placeholder (V1 no real auth, same as ReviewDecision).
model HotEventRevision {
  id         String   @id // UUIDv7, assigned in application code (newTraceId)
  hotEventId String   @map("hot_event_id")
  title      String
  tags       String[] @default([])
  reviewer   String
  note       String?
  traceId    String?  @map("trace_id")
  createdAt  DateTime @default(now()) @map("created_at")

  hotEvent HotEvent @relation(fields: [hotEventId], references: [id])

  @@index([hotEventId])
  @@index([createdAt])
  @@map("hot_event_revisions")
}

// An append-only market-reaction snapshot for a HotEvent (AD-2/AD-5, Story 2.1).
// The market-reaction module is the sole writer of this table. Each row records
// ONE market snapshot's TWO signal dimensions — price/volume (priceVolumeTone +
// priceVolumeValue) and sector/limit-up (sectorLimitUpTone + sectorLimitUpValue
// + limitUpCount) — plus a tradingSession time context shared by both signals
// (epic: every signal carries an explicit trading-session time context). Rows are
// NEVER updated or deleted: every generation appends a new row, so the table is a
// time series of snapshots for the event (HOT_EVENT ||--o{ REACTION_SNAPSHOT).
// The public read model projects the LATEST row (createdAt desc, id desc tiebreak)
// into published_hot_event_reactions; the market-reaction worker V1 only generates
// the initial snapshot for a published event with no snapshot.
//
// FK onDelete: Cascade so a HotEvent deletion cleans up its snapshot history.
// `source` distinguishes provenance ("template" V1 deterministic fixture-backed
// derivation; future provider id when a real market-data adapter is wired). V1
// worker runtime resolves NO adapter → no snapshot is written → prod degrades
// honestly (AC3); StubMarketDataAdapter is test-only (verify/e2e).
//
// NFR: signals are explanatory, never advisory — tone/value describe observed
// market facts (change percent, sector name, limit-up count) and NEVER contain
// buy/sell/target-price/position wording.
//
// The flat 2-dimension column layout (not a JSON signals array) mirrors V1 AC
// (exactly two required dimensions) and maps directly to ReactionChip's
// {tone, value}. Adding a future third dimension (e.g. capital flow) is a
// schema migration (deferred).
model MarketReactionSnapshot {
  id                 String   @id // UUIDv7, assigned in application code (newTraceId)
  hotEventId         String   @map("hot_event_id")
  priceVolumeTone    String   @map("price_volume_tone") // ReactionTone union value ("up"|"down"|"flat")
  priceVolumeValue   String   @map("price_volume_value")
  sectorLimitUpTone  String   @map("sector_limit_up_tone") // ReactionTone union value
  sectorLimitUpValue String   @map("sector_limit_up_value")
  limitUpCount       Int      @map("limit_up_count")
  tradingSession     DateTime @map("trading_session")
  source             String // ReactionSource union value ("template"; future provider id)
  traceId            String?  @map("trace_id")
  createdAt          DateTime @default(now()) @map("created_at")

  hotEvent HotEvent @relation(fields: [hotEventId], references: [id], onDelete: Cascade)

  @@index([hotEventId])
  @@index([createdAt])
  @@map("market_reaction_snapshots")
}

