// The append-only write table for a daily digest (AD-2, Story 2.4). The digest
// module is the sole writer. One row per generation; every successful
// generateDailyDigest call APPENDS a new row (AD-5: never update or delete prior
// rows — the full digest history is the version series). publish-orchestrator
// projects the LATEST row for a coverageDate (createdAt desc, id desc tiebreaker)
// into published_daily_digests.
//
// `coverage_date` is the trading day this digest covers (V1: the UTC day of the
// member events' latestEvidenceAt — a real trading calendar is deferred). It is
// NOT unique: multiple generations for the same coverageDate append multiple
// rows; the public projection takes the latest.
//
// `items` is a Json column holding DailyDigestEntry[] ({hotEventId,title,
// conclusion,latestEvidenceAt,evidenceCount}). These are display-only editorial
// entries: the /daily page reads the whole array to render one clickable row
// per event. A normalized child table would be over-engineering for a
// display-only, variable-cardinality set that is always read whole (ponytail:
// no child table for a consumerless per-entry SQL query — mirrors the 2.2/2.3
// items-Json decision). The digest aggregate is keyed by coverageDate (NOT
// hotEventId), so it has NO FK to hot_events — hotEventId is a data-only
// foreign-key-style link (epic: "cross-page navigation is not a module ...
// foreign-key-style links between them (DAILY_DIGEST → HOT_EVENT)"). This means
// a hotEvent takedown does NOT cascade-clear the digest (the digest is a
// versioned point-in-time artifact; the link honestly 404s, staleness recompute
// is deferred).
//
// NFR: conclusions are explanatory, never advisory — describe the day's key
// events, NEVER buy/sell/target-price/position wording. generateDailyDigest
// validates each conclusion via noInvestAdvice (throws on a keyword hit, AC2
// fail-fast).
model DailyDigest {
  id           String   @id // UUIDv7, assigned in application code (newTraceId)
  coverageDate DateTime @map("coverage_date")
  items        Json // DailyDigestEntry[] ({hotEventId,title,conclusion,latestEvidenceAt,evidenceCount}); display-only
  source       String // DigestSource union value ("template"; future llm/provider id)
  traceId      String?  @map("trace_id")
  createdAt    DateTime @default(now()) @map("created_at")

  // No FK to hot_events — the digest is a coverageDate-keyed aggregate, not a
  // hotEvent-owned sub-aggregate. hotEventId in each entry is a data-only link.
  @@index([coverageDate])
  @@index([createdAt])
  @@map("daily_digests")
}

// The public read model for a daily digest (AD-3, Story 2.4). The publish-
// orchestrator module is the sole writer. Row existence = a currently-published
// digest for that coverageDate: refreshPublishedDailyDigest upserts the row
// (projecting the latest DailyDigest for the coverageDate), or deleteMany's it
// when no DailyDigest row exists. There is intentionally NO status column — row
// existence is the visibility contract (same pattern as the other published_*
// read models). coverageDate is the PK (one projected digest per coverageDate).
//
// Unlike the published_hot_event_* read models, this table has NO FK to
// hot_events — the digest is a coverageDate-keyed aggregate (mirroring the
// write table's no-FK decision). `source` records the provenance of the
// projected digest (operator audit), and `generated_at` records when that
// digest was generated (so the public surface can show "日报生成于 <time>"). A
// row may be ABSENT for a coverageDate if generateDailyDigest has not produced
// a digest (V1 worker resolves no adapter → skip → never produced) — the /daily
// page renders an honest degraded state in that case (AC3, never fabricates a
// digest).
model PublishedDailyDigest {
  coverageDate DateTime @id @map("coverage_date")
  items        Json // DailyDigestEntry[] ({hotEventId,title,conclusion,latestEvidenceAt,evidenceCount}); display-only
  source       String // DigestSource union value
  generatedAt  DateTime @map("generated_at")
  traceId      String?  @map("trace_id")
  updatedAt    DateTime @updatedAt @map("updated_at")

  // No FK to hot_events — coverageDate-keyed aggregate, not hotEvent-owned.

  @@map("published_daily_digests")
}

// A lightweight, credential-free user account (Story 3.2 — deferred-login
// follow action). The user-profile module is the sole writer of this table
// (AD-2 single ownership boundary). An account is just a stable UUIDv7 id with
// NO credential columns (no password hash, no OAuth subject, no email) — the
// "login" action itself creates the account and sets a signed session cookie
// (see apps/web/lib/session.ts). Real credential auth (password / OAuth /
// magic-link / email verification + identity provider selection) is deferred to
// a later epic (registered in deferred-work.md). The upgrade path is additive:
// add credential columns + verify them in createSession/readSession; the follow
// domain logic and FollowButton call surface stay unchanged.
//
// PK is UUIDv7 assigned in application code (createAccount uses uuidv7()),
// mirroring the system-wide app-side PK convention (no DB default).
model UserAccount {
  id        String   @id // UUIDv7, assigned in application code (createAccount)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  followTargets FollowTarget[]

  @@map("user_accounts")
}

// A follow target — one row per (userAccount, targetKind, target) the user has
// followed (Story 3.2). The user-profile module is the sole writer (AD-2).
//
// AD-3 + Single ownership boundary: this table has NO FK to hot_events /
// themes / published_hot_events. A follow row references its target by id
// STRING ONLY — `target_hot_event_id` points at a published_hot_events.id (not
// FK-constrained) and `target_theme_slug` is a plain string. This means a taken-
// down event's follow row stays (3.3 owns the "offline" annotation on the
// watchlist); 3.2 deliberately does NOT validate target existence against
// published_* (AC does not require it). The module NEVER reads or writes
// HotEvent / Theme / published_* aggregates — it only stores/retrieves id
// strings.
//
// Discriminated union at the call surface maps to two nullable columns:
//   - targetKind="hot_event" → target_hot_event_id set, target_theme_slug NULL.
//   - targetKind="theme"     → target_theme_slug set, target_hot_event_id NULL.
// `target_kind` is whitelisted at the application layer (FollowTargetKind
// const in user-profile/types.ts); it is a String column with a TS union (no
// Prisma enum, per erasableSyntaxOnly).
//
// Two partial @@unique constraints guarantee "one user follows a given target
// at most once": partial indexes over NULL-able columns do NOT treat multiple
// NULLs as duplicates (SQL standard), so the hot_event unique applies only to
// rows with a non-null target_hot_event_id, and the theme unique applies only
// to rows with a non-null target_theme_slug. followTarget uses upsert against
// the matching unique, so a repeat follow is idempotent (AC2 / I/O matrix row
// "重复收藏幂等"); unfollowTarget uses deleteMany (idempotent on already-gone).
model FollowTarget {
  id               String   @id // UUIDv7, assigned in application code
  userAccountId    String   @map("user_account_id")
  targetKind       String   @map("target_kind") // FollowTargetKind union ("hot_event"|"theme")
  targetHotEventId String?  @map("target_hot_event_id")
  targetThemeSlug  String?  @map("target_theme_slug")
  createdAt        DateTime @default(now()) @map("created_at")

  userAccount UserAccount @relation(fields: [userAccountId], references: [id], onDelete: Cascade)

  // Partial uniques: one row per (user, kind, target). See model comment for
  // why two are needed (nullable target columns + SQL NULL-not-equal-NULL).
  @@unique([userAccountId, targetKind, targetHotEventId])
  @@unique([userAccountId, targetKind, targetThemeSlug])
  @@index([userAccountId])
  @@map("follow_targets")
}

// The public timeline read model (AD-3b, Story 4.1). publish-orchestrator is
// the sole writer. Each row is a per-HotEvent FOLDED entry projected from the
// member EvidenceRecords: a HotEvent with >= TIMELINE_FOLD_THRESHOLD (default 2,
// owned by event-assembly) member sources folds into ONE row carrying the set of
// folded evidence_record ids; a single-source event is one independent row. The
// home timeline reads this table grouped by trade_date (A-share trading day),
// ordered occurred_at DESC within each group (session_tag partitions PreOpen /
// Intraday / PostClose / NonTrading). Refresh is gate-atomic (AD-3b method A):
// decideReview's $transaction upserts this row on publish and deletes it on
// takedown beside refreshPublishedReadModel (zero visibility window); a periodic
// self-heal BullMQ job does full corrective recompute as a safety net.
//
// Row existence = currently published (no status column, mirroring the other
// published_* read models). trade_date / occurred_at / session_tag are derived
// via pure functions over A-share trading sessions (session-tag.ts). source_name
// is the representative source (the latest member's source.name when folded;
// same source for a single-source entry). title/summary are the HotEvent's
// effective title (latest revision overlay) and a one-line summary (latest
// ExplanationVersion summary, or "" when none). evidence_count is the member
// EvidenceRecord count; folded_evidence_record_ids holds the folded id set (Json
// string[] — a normalized child table would be over-engineering for a display-
// only set always read whole, mirroring published_hot_event_associations.items).
// recommendation_reason is reserved for Story 5.1 (AI 解读) and stays NULL here.
//
// FK onDelete: Cascade so a HotEvent deletion cleans up its timeline rows. The
// composite index (trade_date, session_tag, occurred_at) backs the home feed
// grouped-descent read and the 4.3 session filter (built once here).
model PublishedTimelineEntry {
  id                      String   @id // UUIDv7, assigned in application code (newTraceId)
  hotEventId              String   @map("hot_event_id")
  tradeDate               String   @map("trade_date") // YYYY-MM-DD (Asia/Shanghai trading day)
  occurredAt              DateTime @map("occurred_at") // UTC instant; max member publishedAt
  sessionTag              String   @map("session_tag") // TimelineSessionTag union (pre_open|intraday|post_close|non_trading)
  sourceName              String   @map("source_name")
  title                   String
  summary                 String
  evidenceCount           Int      @map("evidence_count")
  foldedEvidenceRecordIds Json     @default("[]") @map("folded_evidence_record_ids") // string[] (EvidenceRecord.id)
  // Story 7.5 — projected saliency for timeline ranking, same source/writer as
  // PublishedHotEvent.saliency. Nullable for pre-7.5 rows; listPublishedTimeline
  // orders by occurredAt DESC and uses saliency as a secondary tiebreak / the
  // FR-3 sort-reason source (Story 7.5).
  saliency                Float?   @map("saliency")
  recommendationReason    String?  @map("recommendation_reason") // Story 5.1 slot (AI 解读); NULL until 5.1
  traceId                 String?  @map("trace_id")
  createdAt               DateTime @default(now()) @map("created_at")

  hotEvent HotEvent @relation(fields: [hotEventId], references: [id], onDelete: Cascade)

  // One row per published HotEvent — enforced at the DB. The folded projection
  // is per-event (not global), so a UNIQUE on hot_event_id makes the upsert
  // race-free: a concurrent in-tx publish and the self-heal job cannot create
  // two rows for the same event. The unique index also backs takedown's
  // deleteMany and the upsert's where:{ hotEventId } lookup.
  @@unique([hotEventId])
  @@index([tradeDate, sessionTag, occurredAt])
  @@map("published_timeline_entries")
}

// An append-only AI 解读 (recommendation reason) for a HotEvent (AD-5, Story 5.1).
// The explanation module is the sole writer of this table. Each row records a
// one-line (≤40 字) AI 解读 — the card-surface hook rendered by the 4.2 timeline
// card alongside the AiLabel when published_timeline_entries.recommendation_reason
// is non-null. Rows are NEVER updated or deleted: every generation appends a new
// row, so the full chain (ordered by created_at) is the auditable history of which
// AI 解读 was generated when, by which model, under which prompt version (NFR-7
// version + provenance: model_id + prompt_version + source on every row). The
// publish-orchestrator timeline projection (projectTimelineFields) projects the
// LATEST row (created_at desc first) into published_timeline_entries.recommendation_
// reason — publish-orchestrator stays the SOLE writer of that column (AD-2/AD-3b);
// the worker only appends here + calls refreshPublishedTimelineForEvent.
//
// Distinct from ExplanationVersion (the three-partition detail-page deep read):
// ExplanationVersion is a fixed three-partition schema with NOT NULL hotEventId
// and does not fit the single-line card hook. RecommendationReason is a separate
// append-only table carrying one reason per row (epic-5-context data-model
// decision: three independent append-only tables, do not reuse ExplanationVersion).
//
// FK onDelete: Cascade so a HotEvent deletion cleans up its AI 解读 history.
// `source` is "ai" in V1 (real LLM deferred; the stub also writes "ai" so the
// projection pipeline is identical — only the model_id/prompt_version mark it as
// stub-generated). The recommendation_reason column on published_timeline_entries
// is a DERIVED projection of the latest row here, NOT a second write path.
model RecommendationReason {
  id            String    @id // UUIDv7, assigned in application code (newTraceId)
  hotEventId    String    @map("hot_event_id")
  reason        String // ≤40 字 AI 解读; passesRecommendationGuardrail-enforced at write time
  source        String // ExplanationSource union value ("ai" in V1)
  modelId       String    @map("model_id") // provider + version (e.g. "stub:v1", future "openai:gpt-4o")
  promptVersion String    @map("prompt_version") // prompt template version (e.g. "reason-stub-v1")
  // Story 5.4 — suppression timestamp. Nullable metadata: null while the row is
  // live, set to now() by suppressRecommendationReason (the SOLE writer of this
  // column) when an operator judges the reason misleading and suppresses it via
  // the sibling suppressAiContent path. The content columns are NEVER cleared
  // (NFR-7 audit / traceability intact); only this timestamp marks suppression.
  // publish-orchestrator's timeline projection adds `where:{suppressedAt:null}`
  // so a suppressed reason is skipped at projection time → published_timeline_
  // entries.recommendation_reason goes null (or falls back to an earlier
  // unsuppressed version). The signal is co-located on the source row (which the
  // projection already reads) so no cross-module reverse dependency on
  // review-workflow / ReviewDecision is needed (see spec-5-4 Design Notes).
  suppressedAt  DateTime? @map("suppressed_at")
  traceId       String?   @map("trace_id")
  createdAt     DateTime  @default(now()) @map("created_at")

  hotEvent HotEvent @relation(fields: [hotEventId], references: [id], onDelete: Cascade)

  @@index([hotEventId])
  @@index([createdAt])
  @@map("recommendation_reasons")
}

// Story 5.2 — append-only AI 深读 (event-level "为什么重要" deep read). Same shape
// and ownership rules as RecommendationReason above: rows are append-only, so the
// chain ordered by created_at is the auditable history (NFR-7 version +
// provenance: model_id + prompt_version + source on every row). The
// publish-orchestrator projection (projectDeepRead) projects the LATEST row
// (created_at desc first) into published_hot_event_deep_reads — publish-
// orchestrator stays the SOLE writer of that projection (AD-2/AD-3); the worker
// only appends here + calls refreshPublishedReadModel.
//
// Distinct from ExplanationVersion (a DIFFERENT three-partition: summary/
// whyItMatters/uncertainties — the deterministic template three-block that stays
// on the same detail page). DeepRead is a separate append-only table carrying
// 影响面/受益方/风险点 per row (epic-5-context data-model decision: three
// independent append-only tables, do not reuse ExplanationVersion).
//
// FK onDelete: Cascade so a HotEvent deletion cleans up its AI 深读 history.
// `source` is "ai" in V1 (real LLM deferred; the stub also writes "ai" so the
// projection pipeline is identical — only the model_id/prompt_version mark it as
// stub-generated).
model DeepRead {
  id            String    @id // UUIDv7, assigned in application code (newTraceId)
  hotEventId    String    @map("hot_event_id")
  impactSurface String    @map("impact_surface") // 影响面; ≤120 字; guardrail-enforced at write time
  beneficiaries String // 受益方; ≤120 字; guardrail-enforced at write time
  riskPoints    String    @map("risk_points") // 风险点; ≤120 字; guardrail-enforced at write time
  source        String // ExplanationSource union value ("ai" in V1)
  modelId       String    @map("model_id") // provider + version (e.g. "stub:v1", future "openai:gpt-4o")
  promptVersion String    @map("prompt_version") // prompt template version (e.g. "deepread-stub-v1")
  // Story 5.4 — suppression timestamp. Nullable metadata; same semantics as
  // RecommendationReason.suppressedAt (sole writer = suppressDeepRead; content
  // columns never cleared; projection skips via where:{suppressedAt:null}). See
  // the RecommendationReason comment + spec-5-4 Design Notes for the rationale.
  suppressedAt  DateTime? @map("suppressed_at")
  traceId       String?   @map("trace_id")
  createdAt     DateTime  @default(now()) @map("created_at")

  hotEvent HotEvent @relation(fields: [hotEventId], references: [id], onDelete: Cascade)

  @@index([hotEventId])
  @@index([createdAt])
  @@map("deep_reads")
}

// Public read-model projection of the latest DeepRead row (AD-3 public projection,
// one row per published HotEvent). publish-orchestrator is the SOLE writer
// (projectDeepRead inside refreshPublishedReadModel; AD-2/AD-3); the detail page
// reads it via getPublishedHotEventDetail. deep_read_source/generated_at come from
// the latest DeepRead row (always "ai" in V1). Cleared on takedown alongside the
// other published_* read models. Mirrors published_hot_event_explanations.
model PublishedHotEventDeepRead {
  hotEventId     String   @id @map("hot_event_id")
  impactSurface  String   @map("impact_surface")
  beneficiaries  String
  riskPoints     String   @map("risk_points")
  deepReadSource String   @map("deep_read_source") // ExplanationSource union value
  generatedAt    DateTime @map("generated_at")
  traceId        String?  @map("trace_id")
  updatedAt      DateTime @updatedAt @map("updated_at")

  hotEvent HotEvent @relation(fields: [hotEventId], references: [id], onDelete: Cascade)

  @@map("published_hot_event_deep_reads")
}

// 投资标的池 — append-only AI artifact (agent-driven ashare-news-investment-targets
// skill). One row per event per agent run. candidates is a serialized array of
// {name, code, codeVerified, tier, benefitLogic, scores, toVerify, evidenceChain}
// (Json column — mirrors TrendBriefing.basedOnHotEventIds: no operator, no per-
// target query need, so no normalization). NO suppressedAt: there is no operator
// path; a bad run simply writes nothing (honest degradation, like the V1 no-adapter
// default of the sibling AI tables). publish-orchestrator projects the LATEST row
// (created_at desc) into published_hot_event_investment_targets; the chain ordered
// by created_at is the auditable history (NFR-7: model_id + prompt_version + source
// on every row). The agent runs阶段A (extract+score) +阶段B (verify codes) only;
// 阶段C (技术面/买卖点) is not in the output schema and never lands here (PRD §10
// guardrail). Scoring is the skill's 70-point降级口径 (30 points of per-stock
// realtime data the system does not have → carried as downgradeNote).
//
// FK onDelete: Cascade so a HotEvent deletion cleans up its target-pool history.
model InvestmentTarget {
  id               String   @id // UUIDv7, assigned in application code (newTraceId)
  hotEventId       String   @map("hot_event_id")
  newsConclusion   String   @map("news_conclusion") // 新闻一句话结论
  transmissionPath String   @map("transmission_path") // 新闻→行业变量→业绩/估值
  candidates       Json // 候选数组（见 investment-targets 模块 TargetCandidate）
  downgradeNote    String   @map("downgrade_note") // e.g. "含30分待核验项，按70分口径换算"
  source           String // ExplanationSource.Ai
  modelId          String   @map("model_id") // provider + version (e.g. "claude:sonnet-4-6")
  promptVersion    String   @map("prompt_version") // "skill:<sha>|scope-v1"
  traceId          String?  @map("trace_id")
  createdAt        DateTime @default(now()) @map("created_at")

  hotEvent HotEvent @relation(fields: [hotEventId], references: [id], onDelete: Cascade)

  @@index([hotEventId])
  @@index([createdAt])
  @@map("investment_targets")
}

// Public read-model projection of the latest InvestmentTarget row (AD-3 public
// projection, one row per published HotEvent). publish-orchestrator is the SOLE
// writer (projectInvestmentTargets inside refreshPublishedReadModel; AD-2/AD-3);
// the detail page reads it via getPublishedHotEventDetail. generated_at comes from
// the latest InvestmentTarget row. Cleared on takedown alongside the other
// published_* read models. Mirrors published_hot_event_deep_reads (minus the
// suppress dimension — no operator path).
model PublishedHotEventInvestmentTargets {
  hotEventId       String   @id @map("hot_event_id")
  newsConclusion   String   @map("news_conclusion")
  transmissionPath String   @map("transmission_path")
  candidates       Json
  downgradeNote    String   @map("downgrade_note")
  generatedAt      DateTime @map("generated_at")
  traceId          String?  @map("trace_id")
  updatedAt        DateTime @updatedAt @map("updated_at")

  hotEvent HotEvent @relation(fields: [hotEventId], references: [id], onDelete: Cascade)

  @@map("published_hot_event_investment_targets")
}

// Story 5.3 — append-only AI 趋势研判 (daily-page cross-event trend briefing). Same
// shape and ownership rules as DailyDigest above: coverageDate-keyed aggregate (the
// briefing spans the day's events, NOT one hotEvent), rows are append-only, and the
// chain ordered by created_at is the auditable history (NFR-7 version + provenance:
// model_id + prompt_version + source on every row). The publish-orchestrator sibling
// projection (refreshPublishedTrendBriefing) projects the LATEST row (created_at desc
// first) into published_trend_briefings — publish-orchestrator stays the SOLE writer of
// that projection (AD-2/AD-3); the worker only appends here + calls
// refreshPublishedTrendBriefing.
//
// Distinct from DeepRead (per-HotEvent, 影响面/受益方/风险点) and ExplanationVersion
// (per-HotEvent, summary/whyItMatters/uncertainties): TrendBriefing is per-coverageDate
// (one paragraph spanning the day's events). The three independent append-only tables
// follow the epic-5-context data-model decision (three independent tables, do not reuse
// ExplanationVersion). The briefing is a single-paragraph string (not three segments),
// so it does not fit DeepRead's three-column schema either.
//
// NO FK to hot_events (digest-module invariant: "no FK, data-only link, cross-page
// navigation is not a module" — mirrors DailyDigest). `based_on_hot_event_ids` is a
// data-only Json string[] carrying the set of hotEventIds the briefing was derived from
// (satisfies the epic's `TREND_BRIEFING }o--o{ HOT_EVENT : based_on` LOGICAL relation;
// physically a data-only link, same shape as DailyDigest.items). A hotEvent takedown does
// NOT trigger this refresh (the briefing is a versioned point-in-time artifact; the link
// honestly 404s, staleness recompute is deferred — same rule as the daily digest).
//
// `source` is "ai" in V1 (ExplanationSource.Ai value, reused — not DigestSource which has
// no Ai variant; the column stays String and the TS side assigns ExplanationSource.Ai).
// Only the model_id/prompt_version mark a row as stub-generated.
model TrendBriefing {
  id                 String   @id // UUIDv7, assigned in application code (newTraceId)
  coverageDate       DateTime @map("coverage_date")
  briefing           String // ≤200 字 single-paragraph cross-event trend briefing; guardrail-enforced at write time
  basedOnHotEventIds Json     @map("based_on_hot_event_ids") // string[] (hotEventIds the briefing was derived from); data-only link, NO FK
  source             String // ExplanationSource union value ("ai" in V1)
  modelId            String   @map("model_id") // provider + version (e.g. "stub:v1", future "openai:gpt-4o")
  promptVersion      String   @map("prompt_version") // prompt template version (e.g. "trendbriefing-stub-v1")
  traceId            String?  @map("trace_id")
  createdAt          DateTime @default(now()) @map("created_at")

  // NO FK to hot_events — coverageDate-keyed aggregate, data-only based_on_hot_event_ids
  // link (mirrors DailyDigest's no-FK invariant).
  @@index([coverageDate])
  @@index([createdAt])
  @@map("trend_briefings")
}

// Public read-model projection of the latest TrendBriefing row (AD-3 public projection,
// one row per coverageDate). publish-orchestrator is the SOLE writer
// (refreshPublishedTrendBriefing sibling function — coverageDate-keyed, mirrors
// refreshPublishedDailyDigest); the /daily page reads it via getPublishedTrendBriefing.
// source/generated_at come from the latest TrendBriefing row (always "ai" in V1). A row
// may be ABSENT for a coverageDate if generateTrendBriefing has not produced a briefing
// (V1 worker resolves no adapter → skip → never produced, OR the coverageDate has no
// eligible published events) — the /daily page renders an honest degraded state in that
// case (AC3, never fabricates a briefing). coverageDate is the PK (one projected briefing
// per coverageDate). Mirrors published_daily_digests (coverageDate-keyed, no FK).
model PublishedTrendBriefing {
  coverageDate DateTime @id @map("coverage_date")
  briefing     String
  source       String // ExplanationSource union value
  generatedAt  DateTime @map("generated_at")
  traceId      String?  @map("trace_id")
  updatedAt    DateTime @updatedAt @map("updated_at")

  // NO FK to hot_events — coverageDate-keyed aggregate (mirrors published_daily_digests).

  @@map("published_trend_briefings")
}

// Story 8.1 — historical daily OHLC-free bars for a broad index (三大宽基: 上证综指
// sh000001 / 深证成指 sz399001 / 创业板指 sz399006). The Node/Prisma schema owns this
// table (single-schema ownership, AD-2); the Python sidecar apps/market-sidecar is the SOLE
// writer — it writes via psycopg v3 raw SQL only (NEVER Prisma/SQLAlchemy/Alembic). Node
// domain modules (crash-review 8.2, market-reaction) read these rows; they never call AkShare
// (AD-7: external market source behind the MarketDataAdapter port, sidecar is the impl side).
//
// scope is the minimal 大跌日历 foundation: one row per (index_code, trade_date) carrying just
// pct_change + close (decimal, NOT float — Consistency Convention: 涨跌和比率以 decimal 存储).
// OHLC/volume/turnover are YAGNI until a consumer needs them (deferred). trade_date is a DATE
// (A-share trading day, midnight UTC representation); ingested_at is the UTC write instant.
// `source` is "akshare" in V1 (switching providers changes only the sidecar, AD-7). Idempotent
// upsert on @@unique([indexCode, tradeDate]) — re-running the same day is a no-op (AC3). The
// Python side assigns the UUIDv7 `id` app-side (uuid7 lib), mirroring the system-wide
// app-side PK convention (no DB default) so the sidecar is not coupled to a DB id generator.
//
// NO FK to hot_events — this is a market-data time series (a code+date-keyed aggregate), not a
// hotEvent-owned sub-aggregate (mirrors DailyDigest's no-FK invariant). The unique index backs
// the psycopg upsert (ON CONFLICT (index_code, trade_date) DO NOTHING) and the 8.2 crash-review
// latest-bar / date-range reads.
model IndexDailyBar {
  id         String   @id // UUIDv7, assigned in the Python sidecar (uuid7.str → str)
  indexCode  String   @map("index_code") // AkShare-prefixed code ("sh000001"|"sz399001"|"sz399006")
  tradeDate  DateTime @map("trade_date") @db.Date // A-share trading day (UTC midnight)
  pctChange  Decimal  @map("pct_change") @db.Decimal(8, 4) // 涨跌幅 % (signed); decimal not float
  close      Decimal  @db.Decimal(12, 4) // 收盘价; decimal not float
  source     String // MarketDataSource union value ("akshare")
  ingestedAt DateTime @default(now()) @map("ingested_at") // UTC write instant
  traceId    String?  @map("trace_id")

  // Idempotency key: one row per (index, trading day). Backs the upsert ON CONFLICT DO
  // NOTHING and the 8.2 date-range lookup.
  @@unique([indexCode, tradeDate])
  @@index([tradeDate])
  @@index([indexCode])
  @@map("index_daily_bars")
}

// Story 8.1 — historical daily pct_change + close for a 申万一级行业 (~31 industries). Same
// ownership + idempotency model as IndexDailyBar above: Node/Prisma owns the schema; the Python
// sidecar is the SOLE writer (psycopg raw SQL). `sector_code` is the AkShare 申万一级 code;
// `sector_name` is carried per-row (display convenience for the 8.3 public page — a normalized
// sector directory table would be over-engineering for ~31 stable codes, ponytail). trade_date
// is a DATE; pct_change/close are decimal (NOT float). Idempotent upsert on
// @@unique([sectorCode, tradeDate]). NO FK to hot_events — market-data time series.
//
// NOTE: AkShare 申万 function names churn (sw_index_daily vs index_hist_sw); the sidecar's
// akshare_client.py records the EXACT verified function + akshare version at the top. The
// schema is independent of that — it only fixes the row shape.
model SectorDailyBar {
  id         String   @id // UUIDv7, assigned in the Python sidecar (uuid7.str → str)
  sectorCode String   @map("sector_code") // 申万一级 code (AkShare-returned)
  sectorName String   @map("sector_name") // display label, carried per-row
  tradeDate  DateTime @map("trade_date") @db.Date // A-share trading day (UTC midnight)
  pctChange  Decimal  @map("pct_change") @db.Decimal(8, 4) // 涨跌幅 % (signed); decimal not float
  close      Decimal  @db.Decimal(12, 4) // 收盘价; decimal not float
  source     String // MarketDataSource union value ("akshare")
  ingestedAt DateTime @default(now()) @map("ingested_at") // UTC write instant
  traceId    String?  @map("trace_id")

  // Idempotency key: one row per (sector, trading day). Backs the upsert ON CONFLICT DO
  // NOTHING and the 8.2 date-range lookup.
  @@unique([sectorCode, tradeDate])
  @@index([tradeDate])
  @@index([sectorCode])
  @@map("sector_daily_bars")
}

// Story 8.6 — market breadth for a single A-share trading day (one aggregate row per
// trade_date). Same ownership + idempotency model as IndexDailyBar/SectorDailyBar above:
// Node/Prisma owns the schema; the Python sidecar is the SOLE writer (psycopg raw SQL,
// never Prisma/SQLAlchemy/Alembic — single-schema ownership, AD-2). The 8.7 projection
// (published_crash_days.breadth) and 8.8 deep detail page READ this table; they never
// call AkShare (AD-7). trade_date is a DATE and the UNIQUE key — breadth is a per-day
// SINGLE-ROW aggregate of 5 AkShare sources (not per-code like the bar tables).
//
// Core counts (limit_up/down, consecutive_board_max, broken_board_count, advancing/
// declining/flat, total_turnover) are NOT NULL: a breadth row is only written when the
// core count sources return data (NFR-5 — never fabricate; a missing core source ⇒ the
// day is simply absent from the table). `margin_balance_change` (T-1, 融资融券) and
// `dragon_tiger` (龙虎榜) are NULLABLE: a day with no dragon-tiger listings is honestly
// stored as a zero object ({stockCount:0,...}), while a fetch failure stores NULL
// (NFR-5 > the proposal table sketch — see spec Design Notes). `dragon_tiger` is the
// golden-example shape: {stockCount, institutionalNetBuy, hotMoneyNetBuy,
// topStocks:[{code,name,netBuy,reason}]}. total_turnover/margin_balance_change are
// Decimal(20,2) (两市成交额 reaches trillions of yuan); counts are Int. source/ingested_at/
// trace_id make every row traceable (NFR-2). North-bound capital is deliberately NOT
// collected: exchanges stopped real-time disclosure on 2024-08-19, so showing it would
// fabricate empty data.
//
// Idempotent upsert on @@unique([tradeDate]) with ON CONFLICT (trade_date) DO NOTHING —
// re-running a trading day is a no-op and never overwrites an existing row (AC2). NO FK
// to crash_days / index_daily_bars — breadth is a market-data time series keyed by date,
// not a sub-aggregate (mirrors the no-FK invariant above).
model MarketBreadthDaily {
  id                   String   @id // UUIDv7, assigned in the Python sidecar (uuid7.str → str)
  tradeDate            DateTime @map("trade_date") @db.Date // A-share trading day (UTC midnight); unique
  limitUpCount         Int      @map("limit_up_count") // 涨停家数 (stock_zt_pool_em row count)
  limitDownCount       Int      @map("limit_down_count") // 跌停家数 (stock_zt_pool_dtgc_em row count)
  consecutiveBoardMax  Int      @map("consecutive_board_max") // 最高连板高度 (涨停池 连板数 max)
  brokenBoardCount     Int      @map("broken_board_count") // 炸板家数 (stock_zt_pool_zbgc_em row count)
  advancingCount       Int?     @map("advancing_count") // 上涨家数 (spot pctChange > 0); nullable — stock_zh_a_spot_em serves ONLY the latest trading day, so historical-day rows are NULL (NFR-5 honest empty, not fabricated)
  decliningCount       Int?     @map("declining_count") // 下跌家数 (spot pctChange < 0); nullable — advancing/declining/flat/turnover populated only on the latest day (window end)
  flatCount            Int?     @map("flat_count") // 平盘家数 (spot pctChange == 0); nullable — same latest-day-only constraint
  totalTurnover        Decimal? @map("total_turnover") @db.Decimal(20, 2) // 两市成交额(元) (spot 成交额 sum); nullable — spot is latest-day-only, so historical-day rows are NULL (NFR-5)
  marginBalanceChange  Decimal? @map("margin_balance_change") @db.Decimal(20, 2) // 融资融券余额变化(T-1, nullable NFR-5)
  dragonTiger          Json?    @map("dragon_tiger") // 龙虎榜 aggregate (nullable; zero object on no-listing day, NFR-5)
  source               String // MarketDataSource union value ("akshare")
  ingestedAt           DateTime @default(now()) @map("ingested_at") // UTC write instant
  traceId              String?  @map("trace_id")

  // One row per trading day; re-running the same day is a no-op (ON CONFLICT DO NOTHING).
  @@unique([tradeDate])
  @@index([tradeDate])
  @@map("market_breadth_daily")
}

// Story 8.2 — one row per A-share crash trading day. Owned SOLELY by the `crash-review`
// module (AD-2 single-writer), which READS `index_daily_bars` (8.1) and writes here.
// A crash day = any of the three broad indices (sh000001 / sz399001 / sz399006) whose
// pct_change ≤ CRASH_THRESHOLD (default -2.0%, operator-tunable module constant — NOT
// global env, mirroring TIMELINE_FOLD_THRESHOLD). `threshold` is carried per-row so a
// re-tuned recompute is auditable.
//
// `indices` is a read-only statistics projection with no cross-row query need, so per
// the 2026-07-15b sprint-change-proposal #2 it is a single Json column: one entry per
// index present that day ({ indexCode, pctChange, close, crashed, forwardReturns }). A
// missing index_daily_bars row ⇒ that index is omitted (never faked to 0, NFR-5).
// forwardReturns T+1/T+5/T+20 are HISTORIC ACTUAL `(close[t+N]/close[t]-1)*100` over the
// index's own trading-day series; null when fewer than N future bars exist (NFR-5 — no
// fabrication, no extrapolation). These describe observed facts only; advisory wording
// ("非预测/非建议") is a display concern for 8.3, not stored here.
//
// Upsert semantics differ from market_reaction_snapshots (AD-5 append-only): crash_days
// is a materialized projection keyed by tradeDate, so recompute UPDATES in place to
// fill forward returns as new bars arrive (mirrors published_* upsert, NOT append-only).
// NO FK to index_daily_bars — derived projection, not a sub-aggregate. The public read
// model `published_crash_days` is owned by publish-orchestrator and built in 8.3; this
// table is the source-of-truth the projection reads.
model CrashDay {
  id         String   @id // UUIDv7, assigned by crash-review (newTraceId)
  tradeDate  DateTime @map("trade_date") @db.Date // the crash trading day (UTC midnight)
  threshold  Decimal  @db.Decimal(8, 4) // CRASH_THRESHOLD used for this judgement (signed %)
  crashCount Int      @map("crash_count") // how many of the 3 indices crashed (1..3)
  indices    Json // array of IndexCrashDetail (per-index pctChange/close/crashed/forwardReturns)
  source     String // market-data lineage ("akshare")
  computedAt DateTime @default(now()) @map("computed_at") // UTC recompute instant (bumped on recompute)
  traceId    String?  @map("trace_id")

  // One row per crash trading day; recompute upserts in place.
  @@unique([tradeDate])
  @@index([tradeDate])
  @@map("crash_days")
}

// Story 8.3 — published_crash_days: the PUBLIC read model for /crash-calendar, owned
// SOLELY by publish-orchestrator (AD-3 single write-owner). This is the source-of-truth
// the /crash-calendar page reads; it NEVER reads crash_days / index_daily_bars /
// sector_daily_bars directly (AD-3: public reads only published_*). Row existence = a
// currently-published crash day (no status column); absent → page renders the honest
// empty state (AC4, never fabricated).
//
// Mirrors PublishedDailyDigest exactly (coverageDate→tradeDate @id key, no separate id
// column, updatedAt): a crash day is a tradeDate-keyed statistics projection, NOT a
// hotEvent aggregate, so its projection is a SIBLING to refreshPublishedDailyDigest (same
// module, same key family) rather than a branch in the hotEventId-keyed
// refreshPublishedReadModel. NO FK to crash_days / sector_daily_bars — derived projection.
//
// `indices` is copied verbatim from crash_days.indices (IndexCrashDetail[]: per-index
// pctChange/close/crashed/forwardReturns). `leadingSectors` is materialized at projection
// time from sector_daily_bars (Top-N 申万一级 down sectors that trade day — 8.3 is the
// first Node consumer of sector_daily_bars; materializing keeps the page a pure published
// consumer and gives the compliance gate a single control point). Historical bars are
// immutable, so projection-time materialization is never stale. Missing sector rows ⇒
// leadingSectors = [] (the page shows the honest "暂不可用" line, NFR-5).
//
// `breadth` (Story 8.7) is the market-breadth projection from market_breadth_daily (8.6):
// limit-up/down counts, advancing/declining/flat, turnover, margin-balance change, dragon-
// tiger. It is NULLABLE: a crash day whose market_breadth_daily row is absent (sidecar has
// not run that day / predates breadth collection) OR whose breadth read failed projects
// `breadth = null` — the row is still upserted (breadth failure NEVER blocks the published
// crash-day row, NFR-5 honest empty). Decimal fields (totalTurnover/marginBalanceChange)
// are `.toNumber()`-converted at projection time (mirrors leadingSectors.pctChange); the
// 8.6 nullable breadth fields keep their null verbatim (never zeroed). This is the SOLE
// breadth surface the /crash-calendar/[date] page (8.8) consumes; it never reads
// market_breadth_daily directly (AD-3).
model PublishedCrashDay {
  tradeDate      DateTime @id @map("trade_date") @db.Date // the crash trading day (UTC midnight); PK + unique
  threshold      Decimal  @db.Decimal(8, 4) // CRASH_THRESHOLD used for this judgement (signed %, copied from crash_days)
  crashCount     Int      @map("crash_count") // how many of the 3 indices crashed (1..3)
  indices        Json // IndexCrashDetail[] copied verbatim from crash_days
  leadingSectors Json     @map("leading_sectors") // LeadingSector[] ({sectorCode,sectorName,pctChange}) Top-N down, from sector_daily_bars
  breadth        Json?    @map("breadth") // CrashDayBreadth|null — market-breadth projection from market_breadth_daily (8.7); null when the breadth row is absent or the read failed (NFR-5 honest empty, never fabricated)
  source         String // market-data lineage ("akshare")
  publishedAt    DateTime @default(now()) @map("published_at") // UTC projection instant (bumped on reproject)
  traceId        String?  @map("trace_id")
  updatedAt      DateTime @updatedAt @map("updated_at")

  // No FK to crash_days / sector_daily_bars — derived projection, not a sub-aggregate.
  // tradeDate is the PK so it backs both the unique constraint and the calendar range read.

  @@map("published_crash_days")
}
