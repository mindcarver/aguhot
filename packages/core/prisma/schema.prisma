// Prisma 7 schema for @aguhot/core — evidence source ingest & archive.
//
// Generator is `prisma-client` (Prisma 7 default), emitting the typed client
// into ../generated (gitignored, regenerated by `db:generate`). The datasource
// block declares only the provider; the connection string is injected at
// runtime via the @prisma/adapter-pg driver adapter (see src/db.ts) and at
// CLI time via prisma.config.ts. This keeps the public web build free of any
// DATABASE_URL dependency (AD-3/AD-6) while the worker is the single writer
// of the evidence_* tables (AD-2).

generator client {
  provider = "prisma-client"
  output   = "../generated"
}

datasource db {
  provider = "postgresql"
}

// A configured evidence source. source-ingest is the sole write-owner of this
// table (AD-2). `kind` selects which SourceAdapter the worker resolves at
// runtime (AD-7); `feed_url` is the adapter-specific locator (RSS feed URL,
// future API endpoint, etc.). `enabled` gates whether ingestSources() visits
// the source. `last_error` records the most recent per-source failure so a
// single broken source never aborts the rest (AC3 isolation) and stays
// traceable rather than silently dropped.
model EvidenceSource {
  id        String   @id // UUIDv7, assigned in application code (newTraceId)
  name      String
  kind      String // SourceKind union value ("rss"); stored as String, no TS enum
  feedUrl   String  @map("feed_url")
  enabled   Boolean @default(true)
  lastError String? @map("last_error")
  traceId   String? @map("trace_id")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  records EvidenceRecord[]

  @@map("evidence_sources")
}

// An archived evidence record produced from a single ingested item. The
// source-ingest module is the sole writer (AD-2). `content_hash` is the
// deduplication key (sha256 of normalized url+title+published_at): a re-ingest
// of the same item upserts with an empty update (skip) so existing records are
// never overwritten (AC1 dedup). Records with missing required fields are still
// archived with status="missing_fields" and a human-readable failure_reason
// (AC3 traceability) rather than being discarded.
model EvidenceRecord {
  id            String   @id // UUIDv7, assigned in application code (newTraceId)
  sourceId      String   @map("source_id")
  url           String?
  title         String?
  summary       String?
  publishedAt   DateTime? @map("published_at")
  ingestedAt    DateTime @default(now()) @map("ingested_at")
  contentHash   String   @unique @map("content_hash")
  status        String // IngestStatus union value ("archived"|"missing_fields")
  failureReason String?  @map("failure_reason")
  rawPayload    Json     @map("raw_payload")
  traceId       String?  @map("trace_id")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  source EvidenceSource @relation(fields: [sourceId], references: [id])

  // Read-only reverse relation (Prisma navigation metadata, not a write path):
  // lets event-assembly query unlinked archived records efficiently via
  // `where: { evidenceLinks: { none: {} } }` (compiles to NOT EXISTS). Adding
  // this relation does NOT change source-ingest's write-ownership of
  // evidence_records (AD-2): event-assembly only writes hot_event_evidence rows
  // that reference evidence_records.id, never evidence_records itself.
  evidenceLinks HotEventEvidence[]

  // Indexes reference the Prisma field name, not the @map column name.
  @@index([sourceId])
  @@index([status])
  @@map("evidence_records")
}

// A candidate hot event produced by clustering archived evidence records.
// The event-assembly module owns creation + (title, cluster_signature) writes
// (AD-2); review-workflow owns the `publication_status` field writes (AD-6 —
// field-level write-ownership, see Design Notes in spec-1-6: two modules write
// hot_events but different, non-overlapping fields). A candidate is never
// visible publicly until review-workflow transitions publication_status to
// "published" and publish-orchestrator upserts the published_hot_events read
// model. event-assembly only ever assigns "candidate"; review-workflow drives
// candidate→published / candidate→rejected / published→taken_down.
//
// `publication_status` is a String column with a TS union (no Prisma enum, per
// erasableSyntaxOnly). The authoritative union lives in shared/publication-
// status.ts (candidate|published|rejected|taken_down) and is re-exported from
// event-assembly/types.ts to keep the 1-5 public API stable. `cluster_signature`
// is the sorted token-union signature of the cluster's member records (see
// signatureOf in clustering.ts); it is the key used for incremental merge: a
// newly archived record whose tokens overlap an existing candidate's signature
// joins that candidate instead of spawning a duplicate. `title` is a naive
// derivation (latest published_at record's title, non-AI) — real title/
// explanation generation is the separate explain job (1.8).
model HotEvent {
  id                 String   @id // UUIDv7, assigned in application code (newTraceId)
  title              String
  clusterSignature   String   @map("cluster_signature")
  publicationStatus  String   @map("publication_status") // PublicationStatus union value (shared/publication-status.ts)
  traceId            String?  @map("trace_id")
  createdAt          DateTime @default(now()) @map("created_at")
  updatedAt          DateTime @updatedAt @map("updated_at")

  evidence           HotEventEvidence[]
  // Read-only reverse relations (Prisma navigation metadata, not write paths):
  // let review-workflow list candidates / detail evidence and let
  // publish-orchestrator compute read-model projections without a second query
  // round-trip. Adding these does NOT change event-assembly's write-ownership
  // of (title, cluster_signature) or review-workflow's ownership of
  // publication_status (AD-2/AD-6 field-level split).
  reviewDecisions     ReviewDecision[]
  publicationDecisions PublicationDecision[]
  publishedReadModel  PublishedHotEvent?

  @@index([publicationStatus])
  @@map("hot_events")
}

// Link table between a candidate HotEvent and its supporting EvidenceRecord.
// Each candidate is traceable to >= 1 evidence record (AC1). The link table is
// also the "already processed" marker: clusterEvents queries archived records
// with `evidenceLinks: { none: {} }` (NOT EXISTS), so a re-run over the same
// evidence set has an empty processing set — the idempotency key. The unique
// constraint on (hot_event_id, evidence_record_id) is the tail guard against a
// duplicate link under concurrency.
model HotEventEvidence {
  id               String   @id // UUIDv7, assigned in application code (newTraceId)
  hotEventId       String   @map("hot_event_id")
  evidenceRecordId String   @map("evidence_record_id")
  traceId          String?  @map("trace_id")
  createdAt        DateTime @default(now()) @map("created_at")

  hotEvent     HotEvent       @relation(fields: [hotEventId], references: [id])
  evidenceRecord EvidenceRecord @relation(fields: [evidenceRecordId], references: [id])

  @@unique([hotEventId, evidenceRecordId])
  @@index([evidenceRecordId])
  @@index([hotEventId])
  @@map("hot_event_evidence")
}

// An append-only operator decision on a candidate HotEvent (AD-5/AD-6). The
// review-workflow module is the sole writer of this table. Each row records one
// approve/reject/takedown outcome; rows are never updated or deleted — the full
// chain (ordered by created_at) is the auditable history of who decided what,
// when, and why. `outcome` is a String column with the ReviewOutcome union
// (approve|reject|takedown). FK onDelete: Restrict so deleting a HotEvent can
// never silently erase review history (audit traceability, AD-5).
model ReviewDecision {
  id        String   @id // UUIDv7, assigned in application code (newTraceId)
  hotEventId String  @map("hot_event_id")
  outcome   String // ReviewOutcome union value ("approve"|"reject"|"takedown")
  reviewer  String // operator identity (V1: placeholder; real auth deferred)
  note      String? // optional operator note
  traceId   String? @map("trace_id")
  createdAt DateTime @default(now()) @map("created_at")

  hotEvent          HotEvent           @relation(fields: [hotEventId], references: [id])
  publicationDecision PublicationDecision?

  @@index([hotEventId])
  @@index([createdAt])
  @@map("review_decisions")
}

// An append-only record of a publication_status transition (AD-5/AD-6). The
// review-workflow module is the sole writer. Each row records the from→to
// transition driven by a ReviewDecision (linked via review_decision_id) and is
// the auditable proof that a candidate became published, was rejected, or a
// published event was taken down. Rows are never updated or deleted. FK
// onDelete: Restrict so deleting a HotEvent can never erase publication history.
// `from_status`/`to_status` are PublicationStatus union values.
model PublicationDecision {
  id              String   @id // UUIDv7, assigned in application code (newTraceId)
  hotEventId      String   @map("hot_event_id")
  fromStatus      String   @map("from_status") // PublicationStatus union value
  toStatus        String   @map("to_status") // PublicationStatus union value
  reason          String? // optional operator-facing reason
  reviewDecisionId String? @unique @map("review_decision_id")
  traceId         String?  @map("trace_id")
  createdAt       DateTime @default(now()) @map("created_at")

  hotEvent       HotEvent       @relation(fields: [hotEventId], references: [id])
  reviewDecision ReviewDecision? @relation(fields: [reviewDecisionId], references: [id])

  @@index([hotEventId])
  @@index([createdAt])
  @@map("publication_decisions")
}

// The public read model for published hot events (AD-3). The publish-
// orchestrator module is the sole writer of this table. Row existence = current
// publication: approve upserts the row (public-visible), takedown deletes it
// (public-invisible). There is intentionally NO status column — row existence
// is the visibility contract, so public reads are just "SELECT * FROM
// published_hot_events" with no WHERE filter to forget (see Design Notes in
// spec-1-6). FK onDelete: Cascade so a HotEvent deletion cleans up its read
// model row (the decision history is preserved in review_decisions/
// publication_decisions via their own Restrict FKs). `published_at` is the time
// this event became public (set on first publish; kept stable across refreshes).
// `evidence_count`/`latest_evidence_at` are recomputed on every publish refresh.
model PublishedHotEvent {
  hotEventId       String   @id @map("hot_event_id")
  title            String
  evidenceCount    Int      @map("evidence_count")
  latestEvidenceAt DateTime @map("latest_evidence_at")
  publishedAt      DateTime @default(now()) @map("published_at")
  traceId          String?  @map("trace_id")
  updatedAt        DateTime @updatedAt @map("updated_at")

  hotEvent HotEvent @relation(fields: [hotEventId], references: [id])

  @@map("published_hot_events")
}
