// via an in-memory join (listPublishedThemeMemberships → JS dedup by slug), and
// the /topics/[slug] page filters members by slug in JS. A normalized Theme
// directory table + member child table would be over-engineering for a
// display-only, variable-cardinality set read whole (ponytail: no directory
// table for a consumerless single-theme SQL query — slug is the URL, label comes
// from Json). Mirrors the 2.2 EventAssociationSet items-Json decision.
model EventThemeSet {
  id         String   @id // UUIDv7, assigned in application code (newTraceId)
  hotEventId String   @map("hot_event_id")
  items      Json // ThemeRef[] ({slug,label,mappingBasis}); display-only
  source     String // ThemeSource union value ("template"; future knowledge-base/provider id)
  traceId    String?  @map("trace_id")
  createdAt  DateTime @default(now()) @map("created_at")

  hotEvent HotEvent @relation(fields: [hotEventId], references: [id], onDelete: Cascade)

  @@index([hotEventId])
  @@index([createdAt])
  @@map("event_theme_sets")
}

// The public read model for a published hot-event's theme membership (AD-3,
// Story 2.3). The publish-orchestrator module is the sole writer. Row existence
// = currently published themes: publish/republish upserts the row (projecting
// the latest EventThemeSet), takedown deletes it. There is intentionally NO
// status column — row existence is the visibility contract (same pattern as the
// other published_* read models). FK onDelete: Cascade so a HotEvent deletion
// cleans up the projection. `theme_source` records the provenance of the
// projected set (operator audit), and `generated_at` records when that set was
// generated. A row may be ABSENT while the event is published if
// generateThemes has not produced a set yet (V1 worker resolves no adapter →
// skip → never produced) — the detail page renders an honest degraded state in
// that case (AC3, never fabricates themes).
model PublishedHotEventTheme {
  hotEventId  String   @id @map("hot_event_id")
  items       Json // ThemeRef[] ({slug,label,mappingBasis}); display-only
  themeSource String   @map("theme_source") // ThemeSource union value
  generatedAt DateTime @map("generated_at")
  traceId     String?  @map("trace_id")
